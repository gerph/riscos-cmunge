#include <stdio.h>
#include <stdlib.h>
#include <ctype.h>
#include <string.h>

#include "kernel.h"

#include "error.h"
#include "options.h"
#include "readfile.h" /* For fields */

#define LINELENGTH (70)

void WriteBlank(void) {

  FILE *file;
  field_t *field;

  if (!opt.blank)
    return;

  file=fopen(opt.infile,"r");
  if (file!=NULL)
    ErrorFatal("File %s already exists - not overwriting",opt.infile);

  printf("Generating blank CMHG template\n");

  file=fopen(opt.infile,"w");

  if (file==NULL)
    ErrorFatal("Cannot write blank template %s",opt.infile);

  fprintf(file,"\
; CMHG template, generated by CMunge " VERSION " (" DATE ")\n\
;\n\
; Customise this to fit the module you are writing\n\n");

  field=fields;

  while (field->name)
  {
    if (field->values.type != ft_alias)
    {
      char *string=field->blank.comment;
      char *str=string;
      while (*str)
      {
        char *start=str;
        char *lastspace=str;
        enum { space, newline, eol } type=space;
        while ((*str) && (*str!='\n') && (str-start< LINELENGTH ))
        {
          if (*str==' ')
            lastspace=&str[1];
          str++;
        }
        if (*str=='\n')
          lastspace=str,type=newline;
        if (*str=='\0')
          lastspace=str,type=eol;
        fprintf(file,"; ");
        if (lastspace==start)
          lastspace=str;
        str=lastspace;
        fwrite(start,1,lastspace-start,file);
        if (type==newline)
          str++;
        fputc(10,file); /* newline */
      }
      fprintf(file,"%s: %s\n\n",field->name,field->blank.value);
    }
    field++;
  }
  fclose(file);
  exit(0); /* And exit NOW because we can't do any more processing */
}
