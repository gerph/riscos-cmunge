#include <stdio.h>
#include <stdlib.h>
#include <ctype.h>
#include <string.h>

#include "datestamp.h"
#include "error.h"
#include "mem.h"
#include "options.h"
#include "system.h"
#include "apcscli.h"

#ifndef GCC_BIN_DIR
#define GCC_BIN_DIR ""
#endif

static char buf[2048];

void AssembleFile(void) {

  int rc;

  if (opt.ofile) {
    int throwback;
#ifdef __riscos
    throwback = opt.throwback;
#else
    throwback = 0;
#endif

    switch (CODE64 ? tc_gcc : opt.toolchain)
    {
      case tc_norcroft:
        {
          unsigned long flags = opt.apcs;
          char *bufend;
          bufend = buf + sprintf(buf, "%s -nowarn %s %s -o %s -apcs ",
                                 NORCROFT_OBJASM,
                                 throwback ? "-throwback " : "",
                                 opt.sfile, opt.ofile);
          bufend += apcscli_buildstring(flags, ~(APCS_32BIT |
                                                 APCS_SWSTACKCHECK),
                                        1, bufend, buf+2048-bufend);
        }
        break;
      case tc_gcc:
      case tc_lcc:
        {
#ifdef GCC_AS64_PATHVAR
            char *gcc_as;
            gcc_as = getenv(CODE64 ? GCC_AS64_PATHVAR : GCC_AS32_PATHVAR);
            if (!gcc_as && CODE64)
                gcc_as = "riscos64-as";
            if (gcc_as)
            {
                sprintf(buf, "%s -c %s -o %s",
                             gcc_as, opt.sfile, opt.ofile);
            }
#else
            if (0)
            {
                /* Empty so we can use else */
            }
#endif
            else
            {
                sprintf(buf, GCC_BIN_DIR "gcc -xassembler -mmodule %s %s -c %s -o %s",
                             (CODE32) ? "-apcs32 -apcsfpv3" : "",
                             throwback ? "-mthrowback" : "",
                             opt.sfile, opt.ofile);
            }
        }
        break;
    }

    /* printf("Command: %s\n",buf); */

    rc = our_system(buf);
    switch (rc) {
      case EXIT_SUCCESS:
        /* Yo, success! print a message ? Nah, just return */
        return;

      case -2:
        /* Erm... not enough memory... or not there... or something... */
        ErrorFatal("Unable to spawn assembler");
        break;

      default:
        /* They returned something icky. Obviously that's a fault; they
           should have already displayed an error as to the fault though.
         */
        fprintf(stderr,"Assembling: %s\n",buf);
        fprintf(stderr,"Assembler returned %i unexpectedly; aborting\n",rc);
        exit(rc);
    }
  }
}
