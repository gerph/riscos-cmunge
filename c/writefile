static void veneers(void) {

  int n;
  int first, first2;
  handler_list l;
  int_list il;

  first = 1;
  n = 0;
  /* Events */
  if (opt.events) {
    fprintf(file, "\tEXPORT\t%s\n", opt.events->name);
    fprintf(file, "%s\n", opt.events->name);
    /* Output the event list */
    if (opt.event_nums) {
      il = opt.event_nums;
      first2 = 1;
      while (il) {
        if (first2) {
          fprintf(file, "\tTEQ\tr0,#%d\n", il->val);
        } else {
          fprintf(file, "\tTEQNE\tr0,#%d\n", il->val);
        }
        il = il->next;
        first2 = 0;
      }
      fprintf(file, "\tMOVNES\tpc,r14\n");
    }
    fprintf(file, "\tSTMDB\tr13!,{r0-r11,r14}\n");
