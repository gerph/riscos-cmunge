#define DCD_OFFSET(label, comment) \
  do { \
    char *_label = STRINGIFY(label); \
    int _len = strlen(_label); \
    char *_tabs = _len < 8 ? "\t\t" : (_len < 16 ? "\t" : ""); \
    if (! CODE64) \
    { \
      fprintf(file, "\tDCD\t%s-_CMUNGE_origin%s\t; %s\n", _label, _tabs, STRINGIFY(comment)); \
    } \
    else \
    { \
      fprintf(file, ".word\t%s-_CMUNGE_origin%s\t// %s\n", _label, _tabs, STRINGIFY(comment)); \
    } \
  } while (0)

#define DCD_OFFSET_FLAGS(label, flags, comment) \
  do { \
    char *_label = STRINGIFY(label); \
    int _len = strlen(_label) + 5 + 8; \
    char *_tabs = _len < 8 ? "\t\t" : (_len < 16 ? "\t" : ""); \
    if (! CODE64) \
    { \
      fprintf(file, "\tDCD\t(%s-_CMUNGE_origin) | 0x%08x\t%s; %s\n", _label, flags, _tabs, STRINGIFY(comment)); \
    } \
    else \
    { \
      fprintf(file, ".word\t(%s-_CMUNGE_origin) | 0x%08x\t%s// %s\n", _label, flags, _tabs, STRINGIFY(comment)); \
    } \
  } while (0)

#define DCD_OFFSET_INDEX(label, n) \
  do { \
    if (! CODE64) \
    { \
      fprintf(file, "\tDCD\t%s%i\t\t-_CMUNGE_origin\n", label, n); \
    } \
    else \
    { \
      fprintf(file, ".word\t%s%i\t\t-_CMUNGE_origin\n", label, n); \
    } \
  } while (0)

#define DCD_VALUE(value, comment) \
