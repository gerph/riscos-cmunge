    { \
      fprintf(file, "\tDCD\t%s\t\t-_CMUNGE_origin\t; %s\n", STRINGIFY(label), STRINGIFY(comment)); \
    } \
    else \
    { \
      fprintf(file, ".word\t%s\t\t-_CMUNGE_origin\t; %s\n", STRINGIFY(label), STRINGIFY(comment)); \
    } \
  } while (0)

