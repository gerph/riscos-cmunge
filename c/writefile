#define STRINGIFY2(label) #label
#define STRINGIFY(label) STRINGIFY2(label)

#define GLOBAL_LABEL(name) \
  GLOBAL_LABEL_NAMED(STRINGIFY(name));

#define GLOBAL_LABEL_NAMED(name) \
  do { \
    if (! CODE64) \
    { \
      fprintf(file, "\n\tEXPORT\t%s\n", name); \
      fprintf(file, "%s\n", name); \
    } \
    else \
    { \
      fprintf(file, "\n.global\t%s\n", name); \
      fprintf(file, "%s:\n", name); \
    } \
  } while (0)

#define LABEL(name) \
  if (! CODE64) \
  { \
    fprintf(file, "%s\n", STRINGIFY(name)); \
  } \
  else \
  { \
    fprintf(file, "%s:\n", STRINGIFY(name)); \
  }

#define LABEL_INDEX(name, n) \
  if (! CODE64) \
  { \
    fprintf(file, "%s%i\n", name, n); \
  } \
  else \
  { \
    fprintf(file, "%s%i:\n", name, n); \
  }

