        fprintf(file,"\tLDR\tr2,[r4]\t; stack chunk pointer\n");
        fprintf(file,"\tTEQ\tr2,#0\t; is it allocated ?\n");
        fprintf(file,"\tMOVNE\tr0,#7\t; if so, free it\n");
