      fprintf(file, "\tLDMIA\tr13!,{r0-r3,r10,r11,pc}^\n");
    else
      fprintf(file, "\tLDMIA\tr13!,{r0-r3,r10,r11,pc}\n");
  } else {
    fprintf(file, "\tSTMDB\tr13!,{r0-r3,r10,r11,r14}\n");
    fprintf(file, "\tMOV\tr10,r13,LSR #20\n");
