static void outstring(const char *s,int terminate, char newline, int translate_underscore) {

  int inquote=0;
  int chars=0;
  long linestartpos = -1;

  while (*s || terminate)
  {
      char c=*s;
      if (!chars)
      {
        if (!CODE64)
          fprintf(file, "\t= ");
      }
      if (translate_underscore && c=='_')
        c = ' ';
      if ((c>31) && (c<127) && (c!='"') && (c!='\\' || s[1]!='\"')) {
        if (!inquote) {
          if (CODE64)
          {
            if (chars)
            {
              fprintf(file, "\n");
              chars = 0;
            }
            linestartpos = ftell(file);
            fprintf(file, ".ascii\t\"");
          }
          else
          {
            chars+=fprintf(file,chars?",\"":"\"");
          }
          inquote=1;
        }
        fputc(c,file);
        chars++;
      } else {
        if (c=='\\')
          s++;
        if (inquote) {
          if (CODE64)
          {
            if (chars)
            {
              fprintf(file, "\"\n");
              chars = 0;
            }
          }
          else
          {
            chars+=fprintf(file,"\"");
          }
          inquote=0;
        }

        if (CODE64)
        {
          int c = (*s=='\n'?newline:(*s & 0xFF));
          if (c == 0)
          {
            long here = ftell(file);
            assert(linestartpos != -1);
            fseek(file, linestartpos + 5, SEEK_SET);
            // Turn into .asciz
            fputc('z', file);
            fseek(file, here, SEEK_SET);
            chars = 0;
          }
          else
          {
            fprintf(file, ".byte\t%u\n", c);
          }
        }
        else
        {
          chars+=fprintf(file,"%s%u",chars?",":"",(int)(*s=='\n'?newline:(*s & 0xFF)));
        }
      }
      if (*s)
        s++;
      else
        terminate=0;
      if ((chars>60)||!(*s||terminate))
      {
        if (inquote)
        {
          fputc('"',file);
        }
        fputc('\n',file);
        inquote=0;
        chars=0;
      }
  }
}

static void asm_header(void) {

  fprintf(file, "%s Generated by CMunge " Module_FullVersionAndDate "\n", COMMENT);
  fprintf(file, "%s CMunge " Copyright_CMunge "\n\n", COMMENT);
  if (opt.base) {
    if (! CODE64)
    {
        fprintf(file, "\tIMPORT\t|Image$$RO$$Base|\n");
        fprintf(file, "\tEXPORT\tImage__RO_Base\n");
        fprintf(file, "\tAREA\tCode_Description, DATA, REL\n");
        fprintf(file, "Image__RO_Base\n");
        fprintf(file, "\tDCD\t|Image$$RO$$Base|\n\n");
    }
    else
    {
        /* FIXME: Image__RO_Base not defined for 64bit*/
    }
  }
  if (opt.toolchain == tc_gcc ||
      opt.toolchain == tc_lcc)
  {
    if (! CODE64)
    {
        fprintf(file, "\
        GBLL    UsingAS\n\
UsingAS SETL    {TRUE}\n");
    }
  }
  if (! CODE64)
  {
    fprintf(file, "\
; Some handy macros\n\
        GBLL    immediate\n\
        MACRO\n\
        Immediate $var\n\
immediate SETL  {FALSE}\n\
        LCLA    count\n\
        LCLA    varcopy\n\
varcopy SETA    $var\n\
        WHILE   count <= 30\n\
 [ ((varcopy:SHL:count) + (varcopy:SHR:(32-count))) :AND: (:NOT: &FF) = 0\n\
immediate SETL  {TRUE}\n\
        MEXIT\n\
 ]\n\
count   SETA    count + 2\n\
        WEND\n\
        MEND\n\
\n\
        MACRO\n\
$label  addr    $reg, $object, $cc\n\
    [ :DEF: UsingAS\n\
$label  ADR$cc.L $reg, $object\n\
    |\n\
        LCLA    value\n\
value   SETA    .-$object+8\n\
        Immediate &$value\n\
 [ immediate\n\
$label  ADR$cc  $reg, $object\n\
 |\n\
$label  ADR$cc.L $reg, $object\n\
 ]\n\
    ]\n\
        MEND\n\
\n\
");
  }

  fprintf(file, "%s Now the REAL module header\n", COMMENT);
  if (! CODE64)
  {
    fprintf(file, "\tAREA\t|!Header$$code|, %s, READONLY%s%s\n\n",
                   (CODE26) ? "CODE" : "CODE, A32bit",
                   (opt.apcs & APCS_REENTRANT) ? ", PIC, REENTRANT" : "",
                   (opt.apcs & APCS_FPE3) ? ", FP3" : "");
  }
  else
  {
    /* FIXME: 64bit section should include code type for the region? */
    fprintf(file, ".section .init.rmf\n\n");
    GLOBAL_LABEL(_rmf64_header);
  }

  if (! CODE64)
  {
    /* Things that everyone needs */
    fprintf(file, "\tIMPORT\t|_Lib$Reloc$Off$DP|\n");
  }
}


static void mod_header(void) {

  if (opt.mode_errors)
    return;

  GLOBAL_LABEL(__module_header);

  LABEL(_CMUNGE_origin);
  if (opt.runnable) {
    DCD_OFFSET(_CMUNGE_start, Start offset);
  } else {
    DCD_VALUE(0, Start offset);
  }
  if (CODE64)
  {
      DCD_OFFSET_FLAGS(_CMUNGE_init, (1<<30), Initialisation offset and architecture flag);
  }
  else
  {
      DCD_OFFSET(_CMUNGE_init, Initialisation offset);
  }
  DCD_OFFSET(_CMUNGE_fin, Finalisation offset);
  if (opt.service) {
    DCD_OFFSET(_CMUNGE_service, Service handler offset);
  } else {
    DCD_VALUE(0, Service handler offset);
  }
  DCD_OFFSET(_CMUNGE_title, Title string offset);
  DCD_OFFSET(_CMUNGE_help, Help string offset);

  if (opt.commands)
  {
    DCD_OFFSET(_CMUNGE_command, Command table offset);
  }
  else
    IF_OPTIMISED_HEADER(opt.swi_base || opt.swi_names || opt.swi_decoder || opt.mfile)
      DCD_VALUE(0, No commands specified);

  if (opt.swi_base) {
    DCD_VALUE(opt.swi_base, SWI chunk base number);
    DCD_OFFSET(_CMUNGE_swi_handler, SWI handler offset);
  } else {
    IF_OPTIMISED_HEADER(opt.swi_names || opt.swi_decoder || opt.mfile)
    {
      DCD_VALUE(0, SWI chunk base number);
      DCD_VALUE(0, SWI handler offset);
    }
  }
  if (opt.swi_names)
    DCD_OFFSET(_CMUNGE_swi_table, SWI table offset);
  else
    IF_OPTIMISED_HEADER(opt.swi_decoder || opt.mfile)
      DCD_VALUE(0, SWI table offset);
  if (opt.swi_decoder)
    DCD_OFFSET(_CMUNGE_swi_decoder, SWI decoding code offset);
  else
    IF_OPTIMISED_HEADER(opt.mfile)
      DCD_VALUE(0, SWI decoding code offset);
  if (opt.mfile)
    DCD_OFFSET(_CMUNGE_message_file, Message file filename offset);
  else
  {
    IF_OPTIMISED_HEADER(opt.mfile)
      DCD_VALUE(0, Message file filename offset);
  }
  if (CODE26)
  {}
  else
    DCD_OFFSET(_CMUNGE_module_flags, Module flags offset);
}

static void strings(void) {

  if (opt.mode_errors)
    return;

  LABEL(_CMUNGE_title);
  outstring(opt.title,1,'\n',0);
  LABEL(_CMUNGE_help);
  outstring(opt.help,1,'\n',1);
#ifndef CMHG_RESOURCE_FILE_ORDERING
  if (opt.mfile) {
    ALIGN();
    LABEL(_CMUNGE_message_file);
    outstring(opt.mfile,1,'\n',0);
  }
#endif
}

static void swi_table(void) {

  swi_list l;

  if (!opt.swi_names)
    return;
  l = opt.swi_names;
  LABEL(_CMUNGE_swi_table);
  while (l) {
    outstring(l->name, 1, '\n', 0);
    l = l->next;
  }
  BYTE(0);
}

static void commands(void) {

/* JRF: 32bit'd */
  help_list l;
  int nentry;
  int n=0;
  int info;

  /* FIXME: Help entries can be commands - should work; or at least mirror CHMG */
  if (!opt.commands)
    return;
  l = opt.commands;
  n = 0;
  while (l) {
    if (l->help_text) {
      LABEL_INDEX("_CMUNGE_ht", n);
      if ((l->invalid_syntax) && (l->add_syntax))
        outstring(l->help_text,0,'\r',0);
      else
        outstring(l->help_text,1,'\r',0);
    }
    if (l->invalid_syntax) {
      LABEL_INDEX("_CMUNGE_is", n);
      outstring(l->invalid_syntax,1,'\r',0);
    }
    l = l->next;
    n++;
  }
  l = opt.commands;
  n = 0; nentry = 0;
  ALIGN();
  LABEL(_CMUNGE_command);
  while (l) {
    outstring(l->name, 1, '\n', 0);
    ALIGN();
    if (l->no_handler)
      WORD(0);
    else
    {
      DCD_OFFSET_INDEX("_CMUNGE_ce", n);
      nentry++;
    }
    info = l->min_args | (l->max_args<<16) | (l->gstrans<<8) |
           (l->fs_command ? (1U<<31) : 0) | (l->status ? (1<<30) : 0) |
           (l->configure ? (1<<30) : 0) | (l->help ? (1<<29) : 0) |
           (l->international ? (1<<28) : 0);
    WORD(info);
    if (l->invalid_syntax)
      DCD_OFFSET_INDEX("_CMUNGE_is", n);
    else
      WORD(0);
    if (l->help_text)
      DCD_OFFSET_INDEX("_CMUNGE_ht", n);
    else
      WORD(0);
    l = l->next;
    n++;
  }
  /* CMHG *doesn't* output the following, because the low byte of the next
     instruction is 0. Hacky or what? For compatibility I'll do the same,
     except when there are no entry points to follow, in which case we
     need the 0 as the following code doesn't have any.
     Note: This 0 byte following the entries is true for CODE26 and CODE32,
           but not for CODE64.
   */
  if (nentry==0)
  {
    WORD(0);
    /* Of course, if there are no entry points there is no point in writing
       out any veneers. */
    return;
  }
  if (CODE64)
  {
    WORD(0);
  }
  l = opt.commands;
  n = 0; nentry=0;
  while (l) {
    if (!l->no_handler)
    {
      if (nentry != 0)
        fprintf(file, "\tB\t_CMUNGE_ce\n");
      LABEL_INDEX("_CMUNGE_ce", n);
      if (! CODE64)
        fprintf(file, "\tMOV\tr2,#%d\n", nentry++);
      else
        fprintf(file, "\tMOV\tx2,#%d\n", nentry++);
    }
    l = l->next;
    n++;
  }
  LABEL(_CMUNGE_ce);
  if (! CODE64)
  {
    fprintf(file, "\tSTMDB\tr13!,{r0,r10,r11,r14}\n");
    fprintf(file, "\tMOV\tr10,r13,LSR #20\n");
    fprintf(file, "\tMOV\tr10,r10,LSL #20\n");
    fprintf(file, "\tLDMIA\tr10,{r4,r5}\n");
    fprintf(file, "\tMOV\tr3,r12\n");
    fprintf(file, "\tLDR\tr12,[r12]\n");
    fprintf(file, "\tLDMIB\tr12,{r11,r12}\n");
    fprintf(file, "\tSTMIA\tr10,{r11,r12}\n");
    fprintf(file, ADD_Lib_Reloc);
    fprintf(file, "\tMOV\tr11,#0\n");
  }
  else
  {
    /* 64bit entry sequence is a little easier */
    fprintf(file, "\tSTP\tx29, x30, [sp, #-16]!\n");
    fprintf(file, "\tMOV\tx29, sp\n");
    fprintf(file, "\tSTR\tx0, [sp, -16]!\n");
    fprintf(file, "\tMOV\tx3, x12\n");
  }
  if (opt.command_codesupplied)
  {
    help_list l;
    int numentries=0;

    l = opt.commands;
    while (l)
    {
      if (!l->no_handler)
        numentries++;
      l=l->next;
    }
    if (! CODE64)
    {
        fprintf(file, "\tMOV\tr14,pc\n");
        fprintf(file, "\tADD\tr14,r14,# _CMUNGE_com_ret - _CMUNGE_com_pc\n");
        LABEL(_CMUNGE_com_pc);
        fprintf(file, "\tCMP\tr2,#%i\n",numentries);
        fprintf(file, "\tADDLO\tpc,pc,r2,LSL #2\n");
        if (opt.helpfn)
        {
            B_EXTERNAL(opt.helpfn);
        }
        else
          fprintf(file, "\tB\t_CMUNGE_nocom_handler\n");
    }
    else
    {
        fprintf(file, "\tADR\tx30, _CMUNGE_com_ret\n");
        LABEL(_CMUNGE_com_pc);
        fprintf(file, "\tCMP\tx2,#%i\n",numentries);
        fprintf(file, "\tBHS\t_CMUNGE_com_outofrange\n");
        fprintf(file, "\tADR\tx4, _CMUNGE_com_dispatchtable\n");
        fprintf(file, "\tADD\tx4, x4, x2, LSL #2\n");
        fprintf(file, "\tBR\tx4\n");

        LABEL(_CMUNGE_com_outofrange);
        if (opt.helpfn)
        { /* Global help handler, if we have one */
            B_EXTERNAL(opt.helpfn);
        }
        else
        {
            /* Fall through to _CMUNGE_nocom_handler */
            fprintf(file, "\tB\t_CMUNGE_nocom_handler\n");
        }

        LABEL(_CMUNGE_com_dispatchtable);
    }

    l = opt.commands;
    while (l)
    {
      if (!l->no_handler)
      {
        if (l->handler)
        {
            B_EXTERNAL(l->handler);
        }
        else
        {
          if (opt.commands)
            fprintf(file, "\tB\t%s\n", opt.helpfn);
          else
            fprintf(file, "\tB\t_CMUNGE_nocom_handler\n");
        }
      }
      l=l->next;
    }
    if (!opt.helpfn)
    {
      LABEL(_CMUNGE_nocom_handler);
      if (! CODE64)
      {
          fprintf(file, "\tMOV\tr0,#0\n"); /* no error (wrong!) */
      }
      else
      {
          fprintf(file, "\tMOV\tx0,#0\n"); /* no error (wrong!) */
      }
    }
    LABEL(_CMUNGE_com_ret);
  }
  else
  {
    BL_EXTERNAL(opt.helpfn);
  }
  if (! CODE64)
  {
      fprintf(file, SUB_Lib_Reloc);
      fprintf(file, "\tSTMIA\tr10,{r4,r5}\n");
      fprintf(file, "\tLDMIA\tr13!,{r1,r10,r11,r14}\n");
      fprintf(file, "\tCMP\tr1,r0\n");
      fprintf(file, "\tCMPNE\tr0,#0\n");
      if (CODE26)
        fprintf(file, "\tBICEQS\tpc,r14,#0x10000000\n");
      else
        fprintf(file, "\tMOVEQ\tpc,r14\n");
      fprintf(file, "\tCMN\tr0,#1\n");
      fprintf(file, "\tMOVEQ\tr0,#0\n");
      if (CODE26)
        fprintf(file, "\tORRS\tpc,r14,#0x10000000\n");
      else
      {
        fprintf(file, "\tMOV\tr1,#0\n");
        fprintf(file, "\tCMP\tr1,#1<<31\n");
        fprintf(file, "\tMOV\tpc,r14\n");
      }
  }
  else
  {
    /* Slightly different returns for the 64bit system:
     *  If we return with x0=-1, the return value is 4, indicating a bad option?
     */
      /* Pull back the original x0 */
      fprintf(file, "\tLDR\tx1, [sp], #16\n");

// x1=x0 => x0
// x0=0  => x0
// x0=-1 => 4   (new value for RISC OS 64)
//       => x0

      fprintf(file, "\tCMP\tx0, #0\n");
      fprintf(file, "\tCCMP\tx0, x1, #4, ne\n");
      fprintf(file, "\tBEQ\t_CMUNGE_ce_exit\n");
      fprintf(file, "\tCMN\tw0, #1\n");
      fprintf(file, "\tMOV\tx1, #4\n");
      fprintf(file, "\tCSEL\tx0, x0, x1, ne\n");
      LABEL(_CMUNGE_ce_exit);
      fprintf(file, "\tLDP\tx29, x30, [sp], #16\n");
      fprintf(file, "\tRET\n");
  }
}

static unsigned int representable(unsigned int i) {

  unsigned int mask;

  mask = 255;
  while (((i & mask) & ~(mask<<2)) == 0)
    mask = (mask << 2) | (mask >> 30);
  return i & mask;
}

static void service(void) {

/* JRF: 32bit */
  unsigned int n, m;
  int_list l;
  int big;
  int first;

  if (!opt.service)
    return;
  if (! CODE64) {
  } else {
    if (!opt.services) {
        /* FIXME: 64bit RISC OS *must* supply the service numbers to handle */
        ErrorFatal("Service numbers must be supplied for 64 bit RISC OS modules");
    }
  }
  if (opt.services) {
    unsigned int min = 0;
    unsigned int found;

    LABEL(_CMUNGE_service_fast);
    if (! CODE64) {
        WORD(0);
    } else {
        WORD(1<<0); /* 64bit RISC OS always uses fast service entry */
    }
    DCD_OFFSET(_CMUNGE_service_fast_entry, Fast service entry offset);
    /* List services in ascending order */
    LABEL(_CMUNGE_service_index);
    do {
      found = 0;
      for (l = opt.services; l; l = l->next)
      {
        if (l->val > min && ((l->val < found) || (found == 0)))
          found = l->val;
      }
      WORD(found);
      min = found;
    } while (found);
    DCD_OFFSET(_CMUNGE_service_fast, Fast service entry table offset);
    LABEL(_CMUNGE_service);
    /* 64bit RISC OS doesn't have this instruction here - it's pointless */
    if (! CODE64)
      fprintf(file, "\tMOV\tr0,r0\n");
  }
  else
  {
    /* Never needed for 64 bit as we must have the service numbers */
#ifdef CMHG_REDUNDANT_FAST_SERVICE
    WORD(0);
    LABEL(_CMUNGE_service);
    if (! CODE64)
      fprintf(file, "\tMOV\tr0,r0\n");
#else
    LABEL(_CMUNGE_service);
#endif
  }

  /* Service selection code for 64bit is completely different - we always use
   * the indexed fast service entry. */
  if (! CODE64) {
    if (opt.services) {
      /* Do we have any 'big' numbers? */
      big = 0;
      for (l = opt.services; l; l = l->next) {
        if (representable(l->val) != l->val) {
          big = 1;
          break;
        }
      }
      /* Now the rejection code */
      if (big) {
        fprintf(file, "\tSTR\tr14,[r13,#-4]!\n");
      }

      l = opt.services;
      first = 1;
      while (l) {
        n = l->val;
        m = representable(n);
        if (n == m) {
          if (first)
            fprintf(file, "\tTEQ\tr1,#0x%02x\n", n);
          else
            fprintf(file, "\tTEQNE\tr1,#0x%02x\n", n);
        } else {
          fprintf(file, "\tMOV\tr14,#0x%02x\n", m);
          n &= ~m;
          do {
            m = representable(n);
            fprintf(file, "\tORR\tr14,r14,#0x%02x\n", m);
            n &= ~m;
          } while (n);
          if (first)
            fprintf(file, "\tTEQ\tr1,r14\n");
          else
            fprintf(file, "\tTEQNE\tr1,r14\n");
        }
        l = l->next;
        first = 0;
      }
      if (big) {
        if (CODE26)
          fprintf(file, "\tLDMNEIA\tr13!,{pc}^\n");
        else
          fprintf(file, "\tLDMNEIA\tr13!,{pc}\n");
        /* CMHG is inefficient here, but I'll match it */
        fprintf(file, "\tLDR\tr14,[r13],#4\n");
      } else {
        if (CODE26)
          fprintf(file, "\tMOVNES\tpc,r14\n");
        else
          fprintf(file, "\tMOVNE\tpc,r14\n");
      }
    }
    GLOBAL_LABEL(_CMUNGE_service_fast_entry);
    fprintf(file, "\tSTMDB\tr13!,{r0-r11,r14}\n");
    fprintf(file, "\tMOV\tr0,r1\n");
    fprintf(file, "\tMOV\tr1,r13\n");
    if (CODE26)
    {
      fprintf(file, "\tMOV\tr6,pc\n");
      fprintf(file, "\tBIC\tr3,r6,#3\n");
      fprintf(file, "\tTEQP\tr3,#3\n");
    }
    else
    {
      fprintf(file, "\tTEQ      pc,pc\n");
      fprintf(file, "\tMOVNE    r8,pc\n");
      fprintf(file, "\tBICNE    r3,r8,#3\n");
      fprintf(file, "\tTEQNEP   r3,#3\n");
      fprintf(file, "\tMRSEQ    r6,cpsr\n");
      fprintf(file, "\tORREQ    r3,r6,#3\n");
      fprintf(file, "\tMSREQ    cpsr_ctl,r3\n");
    }
    fprintf(file, "\tMOV\tr11,#0\n");
    fprintf(file, "\tMOV\tr7,r14\n");
    fprintf(file, "\tMOV\tr10,r13,LSR #20\n");
    fprintf(file, "\tMOV\tr10,r10,LSL #20\n");
    fprintf(file, "\tLDMIA\tr10,{r4,r5}\n");
    // If we haven't set up the r12 value yet, we are not in an initialised state and trying
    // to set up stacks or call the module will have dire consequences.
    fprintf(file, "\tMOV\tr2,r12\n");
    fprintf(file, "\tLDR\tr12,[r12,#0]\n");
    fprintf(file, "\tTEQ\tr12, #0\n");
    if (CODE26)
    {
      fprintf(file, "\tLDMNEIB\tr12,{r8,r9}\n");
      fprintf(file, "\tSTMNEIA\tr10,{r8,r9}\n");
    }
    else
    {
      fprintf(file, "\tLDMNEIB\tr12,{r12,r14}\n");
      fprintf(file, "\tSTMNEIA\tr10,{r12,r14}\n");
    }
    fprintf(file, ADD_Lib_Reloc);
    fprintf(file, "\tIMPORT\t%s\n", opt.service);
    fprintf(file, "\tBLNE\t%s\n", opt.service);
    fprintf(file, "\tMOV\tr14,r7\n");
    if (CODE26)
    {
      fprintf(file, "\tTEQP\tr6,#0\n");
    }
    else
    {
      fprintf(file, "\tTEQ      pc,pc\n");
      fprintf(file, "\tMSREQ    cpsr_ctl,r6\n");
      fprintf(file, "\tTEQNEP   r8,#0\n");
    }
    fprintf(file, SUB_Lib_Reloc);
    fprintf(file, "\tSTMIA\tr10,{r4,r5}\n");
    if (CODE26)
      fprintf(file, "\tLDMIA\tr13!,{r0-r11,pc}^\n");
    else
      fprintf(file, "\tLDMIA\tr13!,{r0-r11,pc}\n");
  } else {
    fprintf(file, "\tRET\n"); /* Non-indexed entry point is never used */

    /* 64bit fast service entry */
    GLOBAL_LABEL(_CMUNGE_service_fast_entry);

    fprintf(file, "\tSTP\tx29, x30, [sp, #-16]!\n");
    fprintf(file, "\tMOV\tx29, sp\n");


    // Store all the registers
    fprintf(file, "\tSUB\tsp, sp, #4*12\n");
    fprintf(file, "\tSTP\tw0, w1, [sp]\n");
    fprintf(file, "\tSTP\tw2, w3, [sp, #4*2]\n");
    fprintf(file, "\tSTP\tw4, w5, [sp, #4*4]\n");
    fprintf(file, "\tSTP\tw6, w7, [sp, #4*6]\n");
    fprintf(file, "\tSTP\tw8, w9, [sp, #4*8]\n");

    // x1 = service number index
    fprintf(file, "\tADR\tx16, _CMUNGE_service_index - 4\n");
    fprintf(file, "\tLDR\tw0, [x16, x1, LSL #2]\n");  // Obtain the service number (1-indexed)
    fprintf(file, "\tMOV\tx1, sp\n");

    // Call entry point
    fprintf(file, "\tBL\t%s\n", opt.service);

    // Restore registers
    fprintf(file, "\tMOV\tx10, x0\n");
    fprintf(file, "\tLDP\tw0, w1, [sp]\n");
    fprintf(file, "\tLDP\tw2, w3, [sp, #4*2]\n");
    fprintf(file, "\tLDP\tw4, w5, [sp, #4*4]\n");
    fprintf(file, "\tLDP\tw6, w7, [sp, #4*6]\n");
    fprintf(file, "\tLDP\tw8, w9, [sp, #4*8]\n");
    fprintf(file, "\tADD\tsp, sp, #4*12\n");

    fprintf(file, "\tLDP\tx29, x30, [sp], #16\n");
    fprintf(file, "\tRET\n");
  }
}

static void start(void) {

  if (!opt.runnable) {
    return;
  }

  if (! CODE64) {
    LABEL(_CMUNGE_start);
    switch (opt.runnable)
    {
      case run_blib:
      case run_clib:
        {
          char *routine;
          if (opt.lib_enter)
            routine = opt.lib_enter;
          else if (opt.runnable == run_blib)
            routine="_blib_entermodule";
          else
            routine="_clib_entermodule";

          B_EXTERNAL(routine);
        }
        break;

      case run_rmaapp_simple: /* an incredibly simple task using RMA space */
        /* FIXME: Not supported for 64bit */
        fprintf(file,"OS_Module * 30\n");
        fprintf(file,"OS_Exit * 17\n");
        fprintf(file,"OS_GenerateError * 43\n");
        fprintf(file,"\n");
        fprintf(file,"\tIMPORT\t|__root_stack_size|, WEAK\n");
