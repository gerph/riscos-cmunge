\tDCD\t|_Lib$Reloc$Off$DP| + &728AA000\n"
#define SUB_Lib_Reloc \
"\t; This is equivalent of 'SUB r10, r10, #0' + |_Lib$Reloc$Off$DP|\n\
\tDCD\t|_Lib$Reloc$Off$DP| + &E24AA000\n"
#define SUB_Lib_Reloc_VC \
