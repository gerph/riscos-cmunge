/* Instantiate the global options struct here */
options opt;

/* Ensure that we remove our temporary file on exit */
static void Options_RemoveFiles(void) {
  if (opt.sfile && opt.stemp)
    remove(opt.sfile);
  if (opt.pfile)
    remove(opt.pfile);
}

